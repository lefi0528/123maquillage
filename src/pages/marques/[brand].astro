---
import Layout from '../../layouts/Layout.astro';
import Database from 'better-sqlite3';
import path from 'path';
import { SHOW_PRICES } from '../../config.js';
export async function getStaticPaths() {
  const dbPath = path.join(process.cwd(), 'skincare.db');
  const db = new Database(dbPath);
  const rows = db.prepare("SELECT DISTINCT brand_name FROM products").all();
  db.close();
  
  const slugify = (text) => {
    return text
      .toLowerCase()
      .trim()
      .normalize('NFD')
      .replace(/[\u0300-\u036f]/g, '')
      .replace(/[^\w\s-]/g, '')
      .replace(/[-\s]+/g, '-')
      .strip('-');
  };

  // Add simple strip helper
  String.prototype.strip = function(char) {
    let str = this;
    while(str.startsWith(char)) str = str.substring(1);
    while(str.endsWith(char)) str = str.substring(0, str.length - 1);
    return str;
  };

  return rows.map(r => {
    const slug = r.brand_name.toLowerCase().trim().normalize('NFD').replace(/[\u0300-\u036f]/g, '').replace(/[^\w\s-]/g, '').replace(/[-\s]+/g, '-').replace(/^-+|-+$/g, '');
    return { 
      params: { brand: slug },
      props: { brandName: r.brand_name } 
    };
  });
}

const { brand } = Astro.params;
const { brandName } = Astro.props;

const dbPath = path.join(process.cwd(), 'skincare.db');
const db = new Database(dbPath);

// Fetch all products by brand
const products = db.prepare("SELECT * FROM products WHERE brand_name = ? ORDER BY loves_count DESC").all(brandName);

db.close();

// Premium schemas for brand category page (Pillar 2)
const brandSchema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": `Cosmétiques & Soins ${brandName} - 123Maquillage`,
  "description": `Découvrez le catalogue complet de la marque ${brandName}. Retrouvez l'analyse des ingrédients et l'avis par type de peau pour chaque soin.`,
  "url": `https://123maquillage.com/marques/${brand}`
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Accueil",
      "item": "https://123maquillage.com/"
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": brandName,
      "item": `https://123maquillage.com/marques/${brand}`
    }
  ]
};
---

<Layout 
  title={`Cosmétiques & Soins ${brandName} - 123Maquillage`}
  description={`Découvrez le catalogue complet de la marque ${brandName}. Retrouvez l'analyse des ingrédients et l'avis par type de peau pour chaque soin.`}
  schema={[brandSchema, breadcrumbSchema]}
>
  <div style="padding: 60px 0 100px 0;">
    <div class="container">
      
      <!-- Back Link -->
      <a href="/" style="display: inline-flex; align-items: center; gap: 8px; color: hsl(var(--text-muted)); font-weight: 500; font-size: 0.95rem; margin-bottom: 40px; transition: var(--transition-fast);" class="back-link">
        <svg style="width: 18px; height: 18px;" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
        </svg>
        Retour à l'accueil
      </a>

      <!-- Brand Header -->
      <div style="margin-bottom: 60px;">
        <span style="font-size: 0.85rem; font-weight: 600; letter-spacing: 0.15em; color: hsl(var(--accent-rose)); text-transform: uppercase; display: block; margin-bottom: 12px;">
          Maison de cosmétiques
        </span>
        <h1 class="editorial-title" style="font-size: 3rem; margin-bottom: 16px;">
          {brandName}
        </h1>
        <p style="color: hsl(var(--text-muted)); font-size: 1.1rem; max-width: 600px;">
          Retrouvez les {products.length} soins phares de la marque {brandName}, analysés en détail selon l'avis de milliers de consommateurs.
        </p>
      </div>

      <!-- Products Grid -->
      <div class="grid-cols-4">
        {products.map(p => (
          <div class="premium-card" style="display: flex; flex-direction: column; justify-content: space-between; min-height: 360px;">
            <div>
              <span style="font-size: 0.75rem; color: hsl(var(--text-muted)); text-transform: uppercase; letter-spacing: 0.05em; display: block; margin-bottom: 8px;">
                {p.primary_category}
              </span>
              <h3 class="editorial-title" style="font-size: 1.25rem; margin-bottom: 8px; line-height: 1.3; font-weight: 500;">
                <a href={`/produits/${p.slug}`} style="color: inherit;">{p.product_name}</a>
              </h3>
            </div>
            
            <div>
              <!-- Rating and loves -->
              <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 16px;">
                <div style="display: flex; align-items: center; gap: 4px; font-weight: 500; font-size: 0.9rem; color: hsl(var(--accent-gold));">
                  <span>★</span>
                  <span>{p.rating.toFixed(1)}</span>
                </div>
                <div style="font-size: 0.8rem; color: hsl(var(--text-muted)); display: flex; align-items: center; gap: 4px;">
                  <span>♥</span>
                  <span>{p.loves_count.toLocaleString()}</span>
                </div>
              </div>
              
              <div style="display: flex; align-items: center; justify-content: space-between; border-top: 1px solid rgba(212, 175, 55, 0.08); padding-top: 16px;">
                {SHOW_PRICES && (
                  <span style="font-weight: 600; font-size: 1.1rem; color: hsl(var(--text-dark));">
                    {p.price_usd > 0 ? `${p.price_usd.toFixed(0)} €` : 'Non renseigné'}
                  </span>
                )}
                <a href={`/produits/${p.slug}`} class="btn btn-primary" style={`padding: 8px 16px; font-size: 0.8rem; border-radius: var(--radius-sm); ${!SHOW_PRICES ? 'margin-left: auto;' : ''}`}>
                  Détails
                </a>
              </div>
            </div>
          </div>
        ))}
      </div>

    </div>
  </div>
</Layout>

<style>
  .back-link:hover {
    color: hsl(var(--accent-rose)) !important;
    padding-left: 4px;
  }
</style>
