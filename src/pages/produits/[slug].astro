  .back-link:hover {
    color: hsl(var(--accent-rose)) !important;
    padding-left: 4px;
  }
  
  .ing-badge:hover {
    background-color: hsl(var(--accent-rose)) !important;
    border-color: hsl(var(--accent-rose)) !important;
    color: white !important;
    transform: translateY(-2px);
  }

  .ingredient-hidden {
    display: none;
  }

  .table-row:hover {
    background-color: rgba(222, 158, 142, 0.02);
  }

