  <!-- Responsive Nav & Search Script -->
  <script>
    // Universal Instant Search Helper
    async function initSearch(inputId, resultsId) {
      const searchInput = document.getElementById(inputId);
      const searchResults = document.getElementById(resultsId);
      
      if (searchInput && searchResults) {
        searchInput.addEventListener('input', async (e) => {
          const query = e.target.value.trim();
          if (query.length < 2) {
            searchResults.style.display = 'none';
            searchResults.innerHTML = '';
            return;
          }

          try {
            const res = await fetch(`/api/search.json?q=${encodeURIComponent(query)}`);
            const data = await res.json();

            if (data && data.results && data.results.length > 0) {
              searchResults.style.display = 'block';
              searchResults.innerHTML = data.results.map(p => `
                <a href="/produits/${p.slug}" class="search-result-item">
                  <div style="display: flex; flex-direction: column;">
                    <span style="font-weight: 500; color: #1C1817; font-size: 0.95rem;">${p.product_name}</span>
                    <span style="font-size: 0.8rem; color: #7A7270;">${p.brand_name} · <span style="color: #D4AF37;">★ ${p.rating.toFixed(1)}</span></span>
                  </div>
                </a>
              `).join('');
            } else {
              searchResults.style.display = 'block';
              searchResults.innerHTML = `
                <div style="padding: 16px; text-align: center; color: #7A7270; font-size: 0.9rem;">
                  Aucun résultat pour "${query}"
                </div>
              `;
            }
          } catch (err) {
            console.error("Error during instant search:", err);
          }
        });

        // Close dropdown when clicking outside
        document.addEventListener('click', (e) => {
          if (!searchInput.contains(e.target) && !searchResults.contains(e.target)) {
            searchResults.style.display = 'none';
          }
        });
      }
    }

    // Initialize both search bars
    initSearch('global-search', 'search-results');
    initSearch('mobile-global-search', 'mobile-search-results');

    // Mobile Toggle Handlers
    const mobileMenuToggle = document.getElementById('mobile-menu-toggle');
    const mobileMenuDrawer = document.getElementById('mobile-menu-drawer');
    const closeMobileMenu = document.getElementById('close-mobile-menu');
    
    if (mobileMenuToggle && mobileMenuDrawer && closeMobileMenu) {
      mobileMenuToggle.addEventListener('click', () => {
        mobileMenuDrawer.style.display = 'flex';
        document.body.style.overflow = 'hidden'; // Lock background scroll
      });
      
      const closeDrawer = () => {
        mobileMenuDrawer.style.display = 'none';
        document.body.style.overflow = '';
      };
      
      closeMobileMenu.addEventListener('click', closeDrawer);
      mobileMenuDrawer.addEventListener('click', (e) => {
        if (e.target === mobileMenuDrawer) {
          closeDrawer();
        }
      });
    }

    const mobileSearchToggle = document.getElementById('mobile-search-toggle');
    const mobileSearchBar = document.getElementById('mobile-search-bar');
    
    if (mobileSearchToggle && mobileSearchBar) {
      mobileSearchToggle.addEventListener('click', () => {
        const isHidden = getComputedStyle(mobileSearchBar).display === 'none';
        if (isHidden) {
          mobileSearchBar.style.display = 'block';
          const input = document.getElementById('mobile-global-search');
          if (input) input.focus();
        } else {
          mobileSearchBar.style.display = 'none';
        }
      });
    }
  </script>


