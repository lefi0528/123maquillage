---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  schema?: Record<string, any>;
}

const { 
  title = "123Maquillage - Diagnostic & Guide de Soins de la Peau", 
  description = "Découvrez notre comparateur de soins intelligent, faites votre diagnostic de peau gratuit et trouvez les produits cosmétiques idéaux pour votre type de peau.",
  schema
} = Astro.props;

// Dynamically generate canonical URL and absolute social sharing image paths
const canonicalURL = new URL(Astro.url.pathname, 'https://123maquillage.com').toString();
const ogImageURL = new URL('/images/og-image.jpg', 'https://123maquillage.com').toString();

// Generate fallback schemas if not provided by the page
let finalSchema = schema;
if (!finalSchema) {
  if (Astro.url.pathname === '/') {
    finalSchema = {
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": "123Maquillage",
      "url": "https://123maquillage.com/",
      "description": "Votre guide de soin dermatologique personnalisé par l'analyse d'avis réels de passionnés de beauté.",
      "potentialAction": {
        "@type": "SearchAction",
        "target": {
          "@type": "EntryPoint",
          "urlTemplate": "https://123maquillage.com/api/search.json?q={search_term_string}"
        },
        "query-input": "required name=search_term_string"
      }
    };
  } else {
    finalSchema = {
      "@context": "https://schema.org",
      "@type": "WebPage",
      "name": title,
      "description": description,
      "url": canonicalURL
    };
  }
}

// Format as modern, valid @graph if it is an array of schemas
let formattedSchema = finalSchema;
if (Array.isArray(finalSchema)) {
  formattedSchema = {
    "@context": "https://schema.org",
    "@graph": finalSchema.map(s => {
      // Remove @context inside individual graph items to avoid repetition
      const { "@context": _, ...rest } = s;
      return rest;
    })
  };
}
