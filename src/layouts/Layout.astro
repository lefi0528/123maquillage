  </style>


  <!-- Premium Newsletter Capture Modal (Pillar 3 & E-E-A-T Lead Generation) -->
  <div id="newsletter-modal" class="newsletter-overlay">
    <div class="newsletter-modal-card animate-slide-up">
      <!-- Close Button -->
      <button id="close-newsletter" class="close-modal-btn" aria-label="Fermer la fenêtre">
        <svg style="width: 20px; height: 20px;" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
      
      <!-- Content -->
      <div class="newsletter-content">
        <span class="newsletter-tag">LE CLUB PRIVÉ</span>
        <h3 class="editorial-title newsletter-title">
          Votre routine idéale, <br/>
          <span class="editorial-italic text-rose">révélée</span>.
        </h3>
        <p class="newsletter-desc">
          Rejoignez plus de 15 000 passionnés de dermo-cosmétique. Recevez nos analyses d'actifs déchiffrées, nos conseils anti-âge exclusifs et bénéficiez de notre guide d'achat confidentiel.
        </p>
        
        <!-- Form -->
        <form id="newsletter-form" class="newsletter-form-block">
          <div style="width: 100%;">
            <input type="email" id="newsletter-email" placeholder="Votre adresse e-mail" required />
          </div>
          <button type="submit" class="btn btn-primary btn-full">
            Rejoindre le Club
          </button>
        </form>
        
        <!-- Success State -->
        <div id="newsletter-success" class="newsletter-success-state" style="display: none;">
          <svg class="success-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          <span style="font-weight: 600; color: hsl(var(--text-dark));">Bienvenue dans le Club !</span>
          <p style="font-size: 0.85rem; color: hsl(var(--text-muted)); margin-top: 4px;">Votre invitation exclusive a été envoyée.</p>
        </div>
        
        <span class="newsletter-privacy">
          🔒 Garanti 100% sans spam. Désinscription en 1 clic.
        </span>
      </div>
    </div>
  </div>

  <script is:inline>
    // Premium Lead Gen Popup Manager (SEO & Interstitial Compliant)
    document.addEventListener('DOMContentLoaded', () => {
      const modal = document.getElementById('newsletter-modal');
      const closeBtn = document.getElementById('close-newsletter');
      const form = document.getElementById('newsletter-form');
      const emailInput = document.getElementById('newsletter-email');
      const successBlock = document.getElementById('newsletter-success');
      
      if (!modal) return;
      
      // Check if user already closed or subscribed recently (within 7 days)
      const lastDismissed = localStorage.getItem('newsletter_dismissed');
      const now = Date.now();
      const oneWeek = 7 * 24 * 60 * 60 * 1000; // 7 days in ms
      
      if (lastDismissed && (now - parseInt(lastDismissed) < oneWeek)) {
        return; // Skip showing
      }
      
      // Delay launch by 4 seconds (Google Interstitial Penalty Protection)
      setTimeout(() => {
        modal.style.display = 'flex';
      }, 4000);
      
      // Close Modal logic
      const dismissModal = () => {
        modal.style.display = 'none';
        localStorage.setItem('newsletter_dismissed', Date.now().toString());
      };
      
      closeBtn.addEventListener('click', dismissModal);
      
      // Close on clicking overlay background
      modal.addEventListener('click', (e) => {
        if (e.target === modal) {
          dismissModal();
        }
      });
      
      // Form submission (POST to SQLite database via /api/subscribe.json)
      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        const email = emailInput.value.trim();
        if (email) {
          try {
            const response = await fetch('/api/subscribe.json', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ email })
            });
            const result = await response.json();
            
            if (response.ok) {
              // Hide form & show beautiful success state
              form.style.display = 'none';
              successBlock.style.display = 'flex';
              
              // Mark as permanently subscribed (set 100 years expiration)
              localStorage.setItem('newsletter_dismissed', (now + 100 * 365 * 24 * 60 * 60 * 1000).toString());
              
              // Close modal gracefully after 2.5 seconds
              setTimeout(() => {
                modal.style.display = 'none';
              }, 2500);
            } else {
              alert(result.error || "Une erreur est survenue.");
            }
          } catch (err) {
            console.error("Subscription error:", err);
            alert("Une erreur de connexion est survenue. Veuillez réessayer.");
          }
        }
      });
    });
  </script>
